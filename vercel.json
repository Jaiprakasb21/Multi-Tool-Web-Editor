{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.propsanchal.com" }
      ],
      "destination": "/irctc/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "propsanchal.com" }
      ],
      "destination": "/irctc/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "tools.propsanchal.com" }
      ],
      "destination": "/tools/$1"
    }
  ]
}